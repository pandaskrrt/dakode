		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^24",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
